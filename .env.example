# LNbits configuration — leave empty to use mock mode (no real Lightning).
# To enable: create wallets in LNbits (http://localhost:5000) and paste keys here.
LNBITS_ADMIN_KEY=
LNBITS_POOL_KEY=

# Pix (Mercado Pago) — leave empty to use mock mode (no real PSP call).
# Get a token at https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=
# Public URL Mercado Pago will POST to when a Pix is paid (e.g. an ngrok/
# cloudflared tunnel during the hackathon). Without it, confirmation only
# works via manual polling on GET /pix/pagamentos/{txid}.
MP_WEBHOOK_URL=
# Nome comercial inofensivo mostrado na descrição da cobrança (seção 8 do
# doc mestre — disfarce financeiro no rail brasileiro).
PIX_NOME_RECEBEDOR="Ateliê Fio de Ouro Materiais Artesanais"

# Custódia compartilhada — preenchido a partir da saída de
# scripts/gerar_multisig.py. Referência de leitura só; o backend nunca
# guarda chave privada de steward.
MULTISIG_DESCRIPTOR=
MULTISIG_ENDERECO=
MULTISIG_QUORUM=2-de-3
MULTISIG_NETWORK=regtest