# Coinos (coinos.io) — carteira Lightning hospedada. Ver
# backend/app/services/coinos.py pro racional completo. COINOS_POOL_TOKEN
# é o JWT de uma conta Coinos dedicada ao pool, obtido via POST /login ou
# POST /register na API do Coinos. Vazio → mock mode.
COINOS_URL=https://coinos.io/api
COINOS_POOL_TOKEN=

# Pix (Mercado Pago) — leave empty to use mock mode (no real PSP call).
# Get a token at https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=
# Public URL Mercado Pago will POST to when a Pix is paid (e.g. an ngrok/
# cloudflared tunnel during the hackathon). Without it, confirmation only
# works via manual polling on GET /pix/pagamentos/{txid}.
MP_WEBHOOK_URL=
# Nome comercial inofensivo mostrado na descrição da cobrança (seção 8 do
# doc mestre — disfarce financeiro no rail brasileiro).
PIX_NOME_RECEBEDOR="Ateliê Fio de Ouro Materiais Artesanais"

# Binance — conversão BRL→sats de volta pro pool após repagamento Pix
# confirmado (o "passo 4" do ciclo). Leave empty to use mock mode (não
# compra/saca nada de verdade). Gerar em https://www.binance.com/pt-BR/my/settings/api-management
# — a chave precisa de permissão "Enable Spot & Margin Trading" (pra comprar
# BTC) e "Enable Withdrawals" (pra sacar via Lightning).
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Custódia compartilhada — preenchido a partir da saída de
# scripts/gerar_multisig.py. Referência de leitura só; o backend nunca
# guarda chave privada de steward.
MULTISIG_DESCRIPTOR=
MULTISIG_ENDERECO=
MULTISIG_QUORUM=2-de-3
MULTISIG_NETWORK=regtest